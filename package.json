{
  "name": "hm-loc-tbb",
  "productName": "Three Brothers Barrow",
  "description": "A ready-made Jarin barrow tomb for heroes to explore",
  "version": "1.3.0",
  "private": true,
  "author": {
    "name": "Tom Rodriguez",
    "email": "toasty@heroiclands.org",
    "url": "https://www.heroiclands.org"
  },
  "x-contact": {
    "discord": "toasty#8538",
    "bluesky": "@toasty.heroiclands.org"
  },
  "homepage": "https://www.heroiclands.org",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/toastygm/hm-loc-tbb/"
  },
  "bugs": "https://github.com/toastygm/hm-loc-tbb/issues",
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "browser": "./scripts/init.js",
  "exports": {
    "import": "./scripts/init.js"
  },
  "scripts": {
    "clean": "node utils/clean.mjs",
    "distclean": "node utils/clean.mjs --distclean",
    "build": "npm ci && npm run build:prepare",
    "build:prepare": "run-p build:db build:module",
    "build:db": "run-s build:assets build:compiledb build:packdb",
    "build:module": "node ./utils/build-module-json.mjs",
    "build:assets": "node utils/copy-assets.mjs",
    "build:compiledb": "node ./utils/packs/build-compendiums.mjs package compile",
    "build:packdb": "node ./utils/packs/build-compendiums.mjs package pack",
    "build:unpackdb": "node ./utils/packs/build-compendiums.mjs package unpack",
    "build:pack-release": "node utils/pack-release.mjs",
    "push:dev": "node utils/push-stage.mjs dev",
    "push:qa": "node utils/push-stage.mjs qa",
    "push:prod": "node utils/push-stage.mjs prod",
    "push:local-dev": "npm run push:qa",
    "deploy:local": "npm run deploy:qa",
    "deploy:qa": "run-s build push:qa",
    "deploy:dev": "run-s build push:dev",
    "deploy:prod": "run-s build push:prod",
    "deploy:release": "run-s build build:pack-release",
    "release": "node utils/release.mjs"
  },
  "devDependencies": {
    "@foundryvtt/foundryvtt-cli": "^1.0.0",
    "@octokit/rest": "^22.0.0",
    "archiver": "^7.0.0",
    "dotenv": "^16.0.0",
    "loglevel": "^1.9.0",
    "loglevel-plugin-prefix": "^0.8.4",
    "npm-run-all2": "^7.0.0"
  }
}
